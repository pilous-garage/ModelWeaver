#!/usr/bin/env bash
set -euo pipefail
# =============================================================================
# auto-bump — automatise le bump .x, check taille git, commit, push, release.
# Usage: auto-bump [--commit] [--push] [--release]
# =============================================================================
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"
REPO_SLUG="pilous-garage/ModelWeaver"
RELEASE_DIR="release-assets"

# ── Couleurs ──
R='\033[0;31m'; G='\033[0;32m'; B='\033[1;34m'; Y='\033[1;33m'; N='\033[0m'
info()  { echo -e "${B}[INFO]${N} $*"; }
ok()    { echo -e "${G}[OK]${N}   $*"; }
warn()  { echo -e "${Y}[WARN]${N} $*"; }
err()   { echo -e "${R}[ERR]${N}  $*"; exit 1; }

# ── Flags ──
DO_COMMIT=false; DO_PUSH=false; DO_RELEASE=false
for a in "$@"; do case "$a" in --commit) DO_COMMIT=true ;; --push) DO_PUSH=true ;; --release) DO_RELEASE=true ;; --help|-h) echo "Usage: $0 [--commit] [--push] [--release]"; exit 0 ;; *) err "flag inconnu: $a" ;; esac; done

export PATH="$HOME/.cargo/bin:$PATH"

# ── 1. Déterminer la version actuelle + bump .x ──
info "détermination version actuelle (GitHub latest)..."
LATEST_TAG=$(gh api "repos/$REPO_SLUG/releases/latest" --jq '.tag_name' 2>/dev/null || echo "v0.6.0")
LATEST_TAG="${LATEST_TAG:-v0.6.0}"
LATEST_NUM=$(echo "$LATEST_TAG" | sed 's/^v//')
# Incrémente le DERNIER segment, peu importe le nombre de points
# (gère vX.Y.Z, vX.Y.Z.W, voire vX.Y.Z.W.V.X si besoin).
IFS='.' read -ra SEGS <<< "$LATEST_NUM"
LAST=$(( ${#SEGS[@]} - 1 ))
SEGS[$LAST]=$(( ${SEGS[$LAST]} + 1 ))
NEW_NUM=$(IFS='.'; echo "${SEGS[*]}")
NEW_TAG="v$NEW_NUM"
info "version actuelle : $LATEST_TAG  →  bump → $NEW_TAG"

# ── 2. Check taille git + arborescence + auto-ignore >1Mo ──
GIT_SIZE=$(du -sm .git 2>/dev/null | awk '{print $1}')
info "taille .git : ${GIT_SIZE} Mo"
if [ "$GIT_SIZE" -gt 50 ]; then
    warn "repo git > 50 Mo → affichage arborescence (niveau 3)"
    echo "═══════════════════════════════════════════════"
    du -h -d 3 --exclude='.git' --exclude='target' --exclude='node_modules' --exclude='.venv' 2>/dev/null | sort -rh | head -40
    echo "═══════════════════════════════════════════════"

    info "auto-ignore fichiers > 1 Mo (hors .git/target/node_modules/.venv)..."
    ADDED=0
    while IFS= read -r f; do
        rel="${f#./}"
        # skip already ignored
        if git check-ignore -q "$rel" 2>/dev/null; then continue; fi
        # skip inside dirs already ignored
        case "$rel" in
            .git/*|target/*|node_modules/*|.venv/*|__pycache__/*|*.pyc) continue ;;
        esac
        echo "$rel" >> .gitignore
        git add .gitignore 2>/dev/null || true
        ADDED=$((ADDED + 1))
        info "  → .gitignore + $rel"
    done < <(find . -type f -size +1M ! -path '*/.git/*' ! -path '*/target/*' ! -path '*/node_modules/*' ! -path '*/.venv/*' 2>/dev/null)
    ok "$ADDED fichiers ignorés (>1 Mo)"
fi

# ── 3. Build: tous les binaires + tar (si --commit ou --release) ──
if $DO_COMMIT || $DO_RELEASE; then
    info "reconstruction des binaires..."

    info "  → main-cli (headless)"
    (cd projetadmin/main-cli && cargo build --release)

    info "  → bootstrap-cli"
    (cd projetadmin/bootstrap-cli && cargo build --release)

    info "  → gui-main (Tauri, frontend embarqué)"
    (cd projetadmin/gui-main && npm run tauri build --no-bundle 2>&1 | tail -3)

    # Injecte la version COMPLÈTE (release tag) dans le binaire bootstrap :
    # Cargo limite à 3 segments, donc on l'embarque via include_str! depuis
    # ce fichier, généré ici avant le build du bootstrap.
    echo "$NEW_NUM" > projetadmin/gui-bootstrap/src-tauri/src/bootstrap-version.txt

    info "  → gui-bootstrap (install wizard)"
    (cd projetadmin/gui-bootstrap && npm run tauri build --no-bundle 2>&1 | tail -3)

    # Assembler les assets dans release-assets/
    mkdir -p "$RELEASE_DIR"
    cp projetadmin/main-cli/target/release/modelweaver-cli                "$RELEASE_DIR/modelweaver-cli"
    cp projetadmin/bootstrap-cli/target/release/modelweaver-bootstrap-cli "$RELEASE_DIR/modelweaver-bootstrap-cli-linux-x86_64"
    cp projetadmin/gui-main/src-tauri/target/release/modelweaver          "$RELEASE_DIR/modelweaver-gui"
    cp projetadmin/gui-bootstrap/src-tauri/target/release/modelweaver-bootstrap "$RELEASE_DIR/modelweaver-bootstrap-linux-x86_64"

    # Construire le tar de release
    info "  → construction tar de release..."
    STAGE="/tmp/opencode/auto-bump-stage"
    rm -rf "$STAGE" && mkdir -p "$STAGE"
    cp "$RELEASE_DIR/modelweaver-gui"         "$STAGE/modelweaver"
    cp "$RELEASE_DIR/modelweaver-cli"         "$STAGE/modelweaver-cli"
    cp projetadmin/gui-main/gui_helper.py     "$STAGE/"
    cp -r services "$STAGE/"
    cp -r modules  "$STAGE/"
    cp requirements.txt "$STAGE/"
    # version.txt porte la version COMPLÈTE (ex: 0.6.0.5) — Cargo ne gère que
    # 3 segments, donc la source de vérité de la release vit ici. Le bootstrap
    # lit ~/.modelweaver/version.txt pour comparer les versions.
    echo "$NEW_NUM" > "$STAGE/version.txt"
    find "$STAGE/services" "$STAGE/modules" -name __pycache__ -type d -exec rm -rf {} + 2>/dev/null || true
    chmod +x "$STAGE/modelweaver" "$STAGE/modelweaver-cli"
    tar -czf "$RELEASE_DIR/modelweaver-release-linux-x86_64.tar.gz" \
        -C "$STAGE" modelweaver modelweaver-cli services modules gui_helper.py requirements.txt version.txt
    echo "$NEW_NUM" > "$RELEASE_DIR/modelweaver-main-version.txt"
    ok "tar : $(tar -tzf "$RELEASE_DIR/modelweaver-release-linux-x86_64.tar.gz" | wc -l) entrées"
    rm -rf "$STAGE"
fi

# ── 4. Commit ──
if $DO_COMMIT; then
    info "commit des changements sources..."
    git add -A
    # retirer les assets de release (pas dans le repo git, mais par sécurité)
    git reset -q -- "$RELEASE_DIR" 2>/dev/null || true
    COMMIT_MSG="V$NEW_NUM: bump release $NEW_TAG"
    git commit -q -m "$COMMIT_MSG" 2>/dev/null || info "aucun changement à commiter"
    ok "commit: $COMMIT_MSG"
fi

# ── 5. Push ──
if $DO_PUSH; then
    BRANCH=$(git branch --show-current)
    info "push branche $BRANCH..."
    git push -u origin "$BRANCH" 2>&1 | tail -1
    info "push tag $NEW_TAG..."
    git tag "$NEW_TAG" HEAD 2>/dev/null || true
    git push origin "$NEW_TAG" 2>&1 | tail -1 || warn "tag déjà présent sur remote (OK)"
    ok "push terminé"
fi

# ── 6. Release GitHub ──
if $DO_RELEASE; then
    info "création release $NEW_TAG avec assets..."
    # le tag est déjà créé par --push, ou on le crée maintenant
    git tag "$NEW_TAG" HEAD 2>/dev/null || true
    if ! gh release view "$NEW_TAG" --repo "$REPO_SLUG" &>/dev/null; then
        gh release create "$NEW_TAG" \
            --title "$NEW_TAG" \
            --notes "Release automatique $NEW_TAG (auto-bump)." \
            --repo "$REPO_SLUG" \
            "$RELEASE_DIR/modelweaver-release-linux-x86_64.tar.gz" \
            "$RELEASE_DIR/modelweaver-bootstrap-cli-linux-x86_64" \
            "$RELEASE_DIR/modelweaver-bootstrap-linux-x86_64" \
            "$RELEASE_DIR/modelweaver-main-version.txt" 2>&1 | tail -2
        ok "release créée : https://github.com/$REPO_SLUG/releases/tag/$NEW_TAG"
    else
        info "release $NEW_TAG existe déjà — upload des assets..."
        gh release upload "$NEW_TAG" \
            "$RELEASE_DIR/modelweaver-release-linux-x86_64.tar.gz" \
            "$RELEASE_DIR/modelweaver-bootstrap-cli-linux-x86_64" \
            "$RELEASE_DIR/modelweaver-bootstrap-linux-x86_64" \
            "$RELEASE_DIR/modelweaver-main-version.txt" \
            --repo "$REPO_SLUG" --clobber 2>&1 | tail -3
        ok "assets uploadés sur $NEW_TAG"
    fi
fi

echo -e "${G}═══════════════════════════════════════════════${N}"
echo -e "${G}  auto-bump terminé → $NEW_TAG${N}"
echo -e "${G}═══════════════════════════════════════════════${N}"