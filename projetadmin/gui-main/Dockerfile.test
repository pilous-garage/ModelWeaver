FROM ubuntu:24.04
RUN apt-get update && apt-get install -y \
    python3 python3-pip sqlite3 libwebkit2gtk-4.1-0 \
    libgtk-3-0 libayatana-appindicator3-1 librsvg2-common \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*
COPY src-tauri/target/release/modelweaver /app/modelweaver
COPY gui_helper.py /app/gui_helper.py
RUN chmod +x /app/modelweaver
ENV HOME=/home/testuser
RUN useradd -m testuser && chown -R testuser:testuser /app /home/testuser
USER testuser
WORKDIR /app
CMD ["/app/modelweaver"]
