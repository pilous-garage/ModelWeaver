#!/usr/bin/env bash
set -euo pipefail
# =============================================================================
# test-gui-bootstrap — copie docker-keep-gui, injecte le binaire du BOOTSTRAP
#                       (installeur GUI), et lance son UI sous xvfb+vnc.
#                       C'est l'UI du bootstrap qui télécharge la release depuis
#                       GitHub, l'installe (~/.modelweaver) et lance le GUI.
#                       Mode interactif : tu cliques Install dans noVNC.
# Container gardé (pas de --rm). Nom: docker-test-gui-bootstrap.
# Usage: projetadmin/test-gui-bootstrap
# =============================================================================
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

BASE_IMAGE="docker-keep-gui"
CONTAINER="docker-test-gui-bootstrap"
BOOTSTRAP_BIN="$REPO_ROOT/projetadmin/gui-bootstrap/src-tauri/target/release/modelweaver-bootstrap"

R='\033[0;31m'; G='\033[0;32m'; B='\033[1;34m'; Y='\033[1;33m'; N='\033[0m'
info() { echo -e "${B}[INFO]${N} $*"; }
ok()   { echo -e "${G}[OK]${N}   $*"; }
warn() { echo -e "${Y}[WARN]${N} $*"; }
err()  { echo -e "${R}[ERR]${N}  $*"; exit 1; }

# ── Vérifications ──
info "vérification image $BASE_IMAGE..."
docker image inspect "$BASE_IMAGE" &>/dev/null || {
    info "construction de $BASE_IMAGE..."
    docker build -t "$BASE_IMAGE" -f "$REPO_ROOT/docker/Dockerfile.keep-gui" "$REPO_ROOT/docker"
    ok "$BASE_IMAGE construite"
}

info "vérification binaire du bootstrap (gui-bootstrap)..."
if [ ! -f "$BOOTSTRAP_BIN" ]; then
    info "construction du binaire bootstrap (tauri)..."
    (cd "$REPO_ROOT/projetadmin/gui-bootstrap" && npm run tauri build --no-bundle 2>&1 | tail -3)
fi
[ -f "$BOOTSTRAP_BIN" ] || err "binaire bootstrap introuvable: $BOOTSTRAP_BIN"
ok "binaire bootstrap : $(ls -lh "$BOOTSTRAP_BIN" | awk '{print $5}')"

# ── Clean si existe ──
if docker ps -a --format '{{.Names}}' | grep -qx "$CONTAINER"; then
    info "suppression du container existant $CONTAINER..."
    docker rm -f "$CONTAINER" >/dev/null
    ok "$CONTAINER nettoyé"
fi

# ── Création container ──
info "création container $CONTAINER (sans --rm → gardé)..."
docker run -d --name "$CONTAINER" -p 5900:5900 -p 6080:6080 -p 8770:8770 "$BASE_IMAGE"
ok "container lancé (pid=$(docker inspect -f '{{.State.Pid}}' "$CONTAINER"))"

# ── Injection du binaire bootstrap (c'est LUI qui fait l'install) ──
info "injection du binaire bootstrap dans le container..."
docker cp "$BOOTSTRAP_BIN" "$CONTAINER:/opt/modelweaver-bootstrap"
docker exec "$CONTAINER" chmod +x /opt/modelweaver-bootstrap
ok "bootstrap injecté (/opt/modelweaver-bootstrap)"

# ── Lancement de l'UI du bootstrap sous xvfb (detached, interactif) ──
info "lancement de l'UI bootstrap sous xvfb (detached)..."
docker exec -d "$CONTAINER" bash -c 'export DISPLAY=:99 WEBKIT_DISABLE_DMABUF_RENDERER=1 GDK_BACKEND=x11; /opt/modelweaver-bootstrap > /tmp/bootstrap.log 2>&1'
sleep 3
if docker exec "$CONTAINER" curl -s -m2 http://localhost:8770/health >/dev/null 2>&1; then
    ok "API daemon déjà UP (port 8770) — le GUI tourne déjà"
else
    warn "API pas encore UP : c'est normal, le bootstrap est interactif."
    warn "Ouvre noVNC, clique Install/Télécharger, puis lance le GUI. L'API se lèvera après."
fi

echo ""
echo -e "${G}═══════════════════════════════════════════════${N}"
echo -e "${G}  $CONTAINER prêt${N}"
echo -e "${B}  Bootstrap UI (navigateur) :${N} http://localhost:6080/vnc.html?autoconnect=true"
echo -e "${B}  VNC :${N} localhost:5900  (x11vnc, no password)"
echo -e "${B}  API :${N} curl http://localhost:8770/health (UP après installation via le bootstrap)"
echo -e "${B}  Bootstrap log :${N} docker exec $CONTAINER tail -f /tmp/bootstrap.log"
echo -e "${B}  Stop  :${N} docker stop $CONTAINER   (gardé, pas --rm)"
echo -e "${G}═══════════════════════════════════════════════${N}"
