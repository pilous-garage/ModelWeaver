# Ignorer tout ce qui est compilé, généré ou dépendances

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node.js
node_modules/
dist/

# Rust / Tauri build artifacts
**/src-tauri/target/
**/src-tauri/Cargo.lock

# Tauri generated schemas
**/src-tauri/gen/schemas/

# TypeScript build info
*.tsbuildinfo
**/vite.config.d.ts
**/vite.config.js

# Release assets (binaires trop lourds pour git)
release-assets/

# Binaires GitHub CLI (trop lourds)
bin/
share/
gh.tar.gz

# Archives générées
*.tar.gz

# Docker test context (généré par test-gui.sh)
projetadmin/docker/
projetadmin/docker-cli/

# Backups Docker
docker-backup/

# Cache et config générés à l'exécution
.modelweaver/*
!.modelweaver/fallback_preferences.yaml
!.modelweaver/litellm_router_proxy.py
!.modelweaver/opencode-wrapper.sh
.modelweaver_config

# Fichiers temporaires
/tmp/
*.tmp

# Recettes téléchargées (cache local, non versionnées)
installed_recipe/

# Config personnelle OpenCode
.opencode/
opencode.json
tui.json

# Clés API
.env

# Archives de backup
*.tar
*.zip

gui-defunct/
gui/
gemini/
gemma/
mistral/

# Logs et rapports
**/tauri_dev.log
**/tauri_build.log
