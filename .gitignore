# Ignorer tout ce qui est compilé, généré ou dépendances

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node.js
node_modules/
gui/installer/node_modules/
gui/installer/dist/

# Rust / Tauri
# Tauri build output (binaire généré)
gui/installer/src-tauri/target/
gui/installer/src-tauri/Cargo.lock

# Backups Docker
docker-backup/

# Cache et config générés à l'exécution
.modelweaver/*
!.modelweaver/fallback_preferences.yaml
!.modelweaver/litellm_router_proxy.py
!.modelweaver/opencode-wrapper.sh
.modelweaver_config

# Fichiers temporaires
/tmp/
*.tmp

# Config personnelle OpenCode
.opencode/
opencode.json
tui.json

# Clés API
.env

# Archives de backup
*.tar
*.zip

# Logs et rapports
**/tauri_dev.log
**/tauri_build.log