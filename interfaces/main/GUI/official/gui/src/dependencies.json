{
  "required": [
    {
      "name": "python3",
      "description": "Python 3.10+ (for core functionality)",
      "check_command": "python3 --version",
      "version_regex": "Python (\\d+\\.\\d+)",
      "min_version": "3.10"
    },
    {
      "name": "sqlite3",
      "description": "SQLite 3.30+ (for database)",
      "check_command": "sqlite3 --version",
      "version_regex": "(\\d+\\.\\d+)",
      "min_version": "3.30"
    }
  ],
  "recommended": [
    {
      "name": "nonexistentdep",
      "description": "Fake dependency to test optional status",
      "check_command": "nonexistentdep --version",
      "version_regex": "(\\d+\\.\\d+)",
      "min_version": "1.0"
    }
  ]
}