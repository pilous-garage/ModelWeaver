{
  "productName": "ModelWeaver",
  "version": "0.7.3",
  "identifier": "com.modelweaver.main",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ModelWeaver",
        "width": 2560,
        "height": 1440,
        "minWidth": 800,
        "minHeight": 600
      },
      {
        "label": "sandbox",
        "title": "ModelWeaver — Agent Sandbox",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://tauri.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8770 http://localhost:8770"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "resources": {
      "../gui_helper.py": "gui_helper.py"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
